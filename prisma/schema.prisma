generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

enum EventCategory {
  social
  educational
  volunteer
  sports
  arts
  general
}

enum EventStatus {
  draft
  published
  cancelled
  past
}

model Event {
  id            Int           @id @default(autoincrement())
  title         String
  description   String
  location      String
  category      EventCategory @default(general)
  status        EventStatus   @default(draft)
  capacity      Int?
  startDateTime DateTime
  endDateTime   DateTime
  organizerId   String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}
