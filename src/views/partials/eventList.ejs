<% if (events && events.length > 0) { %>
    <div class="grid gap-4">
      <% events.forEach((event) => { %>
        <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3><%= event.title %></h3>
              <p><%= event.location %> · <%= event.category %></p>
              <p><%= event.description %></p>
            </div>
  
            <a href="/events/<%= event.id %>">View Event</a>
          </div>
  
          <form method="POST" action="/events/<%= event.id %>/save" class="mt-2">
            <button 
              type="submit"
              class="px-3 py-1 bg-slate-200 rounded hover:bg-slate-300 text-sm"
            >
              Save / Unsave
            </button>
          </form>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-slate-500 text-sm">No events found.</p>
  <% } %>