<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">My RSVPs</h1>
  <p class="text-slate-500 mb-0">
    Review the events you plan to attend and your RSVP history in one place.
  </p>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="grid gap-5 lg:grid-cols-2">
  <article class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <div class="mb-4">
      <h2 class="text-xl font-semibold text-slate-900">Upcoming</h2>
      <p class="text-slate-500 text-sm">
        Events you are attending or waiting on.
      </p>
    </div>

    <% if (upcoming.length === 0) { %>
      <p class="text-slate-500 mb-0">You do not have any upcoming RSVPs yet.</p>
    <% } else { %>
      <div class="grid gap-4">
        <% upcoming.forEach((entry) => { %>
          <section class="rounded-xl border border-slate-200 p-4 bg-slate-50">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-slate-900 mb-1"><%= entry.event.title %></h3>
                <p class="text-slate-500 text-sm mb-1"><%= entry.event.location %></p>
                <p class="text-slate-500 text-sm mb-0">
                  <%= entry.event.startDateTime.toLocaleString() %>
                </p>
              </div>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-blue-100 text-blue-700 uppercase tracking-wide">
                <%= entry.rsvpStatus %>
              </span>
            </div>
            <p class="text-slate-600 text-sm mt-3 mb-3"><%= entry.event.description %></p>
            <form method="post" action="/my-rsvps/<%= entry.event.id %>/cancel" class="m-0">
              <button
                type="submit"
                class="px-3.5 py-2 rounded-lg bg-white text-rose-700 border border-rose-200 cursor-pointer hover:bg-rose-50 text-sm font-medium"
              >
                Cancel RSVP
              </button>
            </form>
          </section>
        <% }) %>
      </div>
    <% } %>
  </article>

  <article class="p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
    <div class="mb-4">
      <h2 class="text-xl font-semibold text-slate-900">Past And Cancelled</h2>
      <p class="text-slate-500 text-sm">
        Previous events and RSVPs that are no longer active.
      </p>
    </div>

    <% if (history.length === 0) { %>
      <p class="text-slate-500 mb-0">Your past and cancelled RSVPs will appear here.</p>
    <% } else { %>
      <div class="grid gap-4">
        <% history.forEach((entry) => { %>
          <section class="rounded-xl border border-slate-200 p-4 bg-slate-50">
            <div class="flex items-start justify-between gap-3">
              <div>
                <h3 class="text-lg font-semibold text-slate-900 mb-1"><%= entry.event.title %></h3>
                <p class="text-slate-500 text-sm mb-1"><%= entry.event.location %></p>
                <p class="text-slate-500 text-sm mb-0">
                  <%= entry.event.startDateTime.toLocaleString() %>
                </p>
              </div>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold bg-slate-200 text-slate-700 uppercase tracking-wide">
                <%= entry.rsvpStatus === "cancelled" ? "cancelled" : entry.event.status %>
              </span>
            </div>
            <p class="text-slate-600 text-sm mt-3 mb-0"><%= entry.event.description %></p>
          </section>
        <% }) %>
      </div>
    <% } %>
  </article>
</section>
