<section id="archive-results" class="grid gap-4">
  <% if (!events || events.length === 0) { %>
    <article class="rounded-xl border border-slate-200 bg-white p-6 shadow-sm">
      <p class="text-slate-500 mb-0">No archived events match this filter.</p>
    </article>
  <% } else { %>
    <% events.forEach((event) => { %>
      <article class="rounded-xl border border-slate-200 bg-slate-50 p-5">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div>
            <div class="flex items-center gap-2 mb-2 flex-wrap">
              <h2 class="text-xl font-semibold text-slate-900 mb-0"><%= event.title %></h2>
              <span class="px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide bg-slate-200 text-slate-700">
                <%= event.status %>
              </span>
            </div>

            <p class="text-slate-500 text-sm mb-1">
              <%= event.location %> · <%= event.category %>
            </p>
            <p class="text-slate-500 text-sm mb-3">
              Ended <%= event.endDateTime.toLocaleString() %>
            </p>
            <p class="text-slate-600 mb-0"><%= event.description %></p>
          </div>

          <a
            href="/events/<%= event.id %>"
            class="px-3.5 py-2 rounded-lg bg-white text-blue-700 border border-slate-200 no-underline hover:bg-blue-50 text-sm font-medium"
          >
            View Details
          </a>
        </div>
      </article>
    <% }) %>
  <% } %>
</section>
