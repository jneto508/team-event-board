<%
  const containerId = `rsvp-toggle-${event.id}`;
  const status = event.viewerRsvpStatus ?? null;
  const canToggle = Boolean(event.canToggleRsvp);

  let badgeText = "Not RSVPed";
  let badgeClasses = "bg-slate-200 text-slate-700";
  let buttonText = "RSVP";

  if (status === "going") {
    badgeText = "Going";
    badgeClasses = "bg-emerald-100 text-emerald-700";
    buttonText = "Cancel RSVP";
  } else if (status === "waitlisted") {
    badgeText = "Waitlisted";
    badgeClasses = "bg-amber-100 text-amber-700";
    buttonText = "Leave Waitlist";
  } else if (status === "cancelled") {
    badgeText = "Cancelled";
    badgeClasses = "bg-slate-200 text-slate-700";
    buttonText = "RSVP Again";
  }

  if (!canToggle) {
    buttonText = "RSVP Unavailable";
  }
%>

<section
  id="<%= containerId %>"
  class="rounded-xl border border-slate-200 bg-white p-4"
>
  <% if (pageError) { %>
    <div class="mb-3">
      <%- include("../../partials/error", { message: pageError }) %>
    </div>
  <% } %>

  <div class="flex items-start justify-between gap-3 flex-wrap">
    <div>
      <p class="text-sm text-slate-500 mb-1">
        <span class="font-medium text-slate-700"><%= event.attendeeCount %></span> going
        ·
        <span class="font-medium text-slate-700"><%= event.waitlistCount %></span> waitlisted
      </p>
      <span class="inline-flex px-2.5 py-1 rounded-full text-xs font-semibold uppercase tracking-wide <%= badgeClasses %>">
        <%= badgeText %>
      </span>
    </div>

    <form
      method="post"
      action="/events/<%= event.id %>/rsvp-toggle"
      hx-post="/events/<%= event.id %>/rsvp-toggle"
      hx-target="#<%= containerId %>"
      hx-swap="outerHTML"
      class="m-0"
    >
      <button
        type="submit"
        class="px-3.5 py-2 rounded-lg text-sm font-medium border
          <%= canToggle
            ? 'bg-blue-600 text-white border-blue-600 hover:bg-blue-700'
            : 'bg-slate-100 text-slate-400 border-slate-200 cursor-not-allowed' %>"
        <%= canToggle ? "" : "disabled" %>
      >
        <%= buttonText %>
      </button>
    </form>
  </div>
</section>
