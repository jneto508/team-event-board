<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-700 mb-2">Published Event</p>
      <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= event.title %></h1>
      <p class="text-slate-500 mb-0"><%= event.location %> · <%= event.category %></p>
    </div>
    <a
      href="/home"
      class="px-3.5 py-2 rounded-lg bg-white text-blue-700 border border-slate-200 no-underline hover:bg-blue-50 text-sm font-medium"
    >
      Back to Home
    </a>
  </div>
  <p class="text-slate-700 mt-4 mb-0"><%= event.description %></p>
</section>

<div
  id="comments-panel"
  class="max-w-3xl"
>
  <%- include("partials/comments_panel", {
    event,
    comments,
    currentUserId,
    commentValue,
    pageError,
    formatRelativeTime
  }) %>
</div>
