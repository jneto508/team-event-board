<!-- event detail page -->
<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <p class="text-sm font-semibold uppercase tracking-wide text-blue-700 mb-2">
        <%= event.status === "draft" ? "Draft Event" : "Published Event" %>
      </p>
      <h1 class="text-3xl font-bold text-slate-900 mb-2"><%= event.title %></h1>
      <p class="text-slate-500 mb-0"><%= event.location %> · <%= event.category %></p>
    </div>
    <a href="/home" class="px-3.5 py-2 rounded-lg bg-white text-blue-700 border border-slate-200 no-underline hover:bg-blue-50 text-sm font-medium">
      Back to Home
    </a>
  </div>

  <% if (event.status === "draft") { %>
    <div class="mt-4 rounded-xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-800">
      This event is currently a draft and is only visible to its organizer and admins.
    </div>
  <% } %>

  <div class="mt-5 grid gap-4 md:grid-cols-2">
    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500 mb-3">Event Details</h2>
      <dl class="space-y-3 text-sm">
        <div>
          <dt class="font-medium text-slate-700">Description</dt>
          <dd class="text-slate-600 mt-1"><%= event.description %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-700">Location</dt>
          <dd class="text-slate-600 mt-1"><%= event.location %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-700">Category</dt>
          <dd class="text-slate-600 mt-1"><%= event.category %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-700">Status</dt>
          <dd class="text-slate-600 mt-1 capitalize"><%= event.status %></dd>
        </div>
      </dl>
    </div>

    <div class="rounded-xl border border-slate-200 bg-white p-4">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-slate-500 mb-3">Scheduling</h2>
      <dl class="space-y-3 text-sm">
        <div>
          <dt class="font-medium text-slate-700">Starts</dt>
          <dd class="text-slate-600 mt-1"><%= event.startDateTime.toLocaleString() %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-700">Ends</dt>
          <dd class="text-slate-600 mt-1"><%= event.endDateTime.toLocaleString() %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-700">Organizer</dt>
          <dd class="text-slate-600 mt-1"><%= event.organizerId %></dd>
        </div>
        <div>
          <dt class="font-medium text-slate-700">Capacity</dt>
          <dd class="text-slate-600 mt-1"><%= typeof event.capacity === "number" && event.capacity > 0 ? event.capacity : "No limit" %></dd>
        </div>
      </dl>
    </div>
  </div>

  <div class="mt-5 grid gap-3 md:grid-cols-3">
    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-500">
      <!-- Feature 5: organizer publish/cancel controls go here -->
      Organizer controls placeholder
    </div>
    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-500">
      <!-- Feature 4: RSVP button/status goes here -->
      RSVP placeholder
    </div>
    <div class="rounded-xl border border-dashed border-slate-300 bg-slate-50 px-4 py-3 text-sm text-slate-500">
      <!-- Feature 12: attendee list entry point -->
      <p class="mb-2 font-medium text-slate-700">Attendee List</p>
      <p class="mb-3 text-slate-500">View the grouped attendee list for this event.</p>
      <a
        href="/events/<%= event.id %>/attendees"
        class="inline-flex items-center rounded-lg border border-slate-300 bg-white px-3 py-2 text-sm font-medium text-blue-700 no-underline hover:bg-blue-50"
      >
        View Attendee List
      </a>
    </div>
  </div>
</section>

<div
  id="comments-panel"
  class="max-w-3xl"
>
  <%- include("partials/comments_panel", {
    event,
    comments,
    currentUserId,
    commentValue,
    pageError,
    formatRelativeTime
  }) %>
</div>
