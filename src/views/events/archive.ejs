<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <div class="flex items-start justify-between gap-4 flex-wrap">
    <div>
      <h1 class="text-3xl font-bold text-slate-900 mb-2">Archived Events</h1>
      <p class="text-slate-500 mb-0">
        Browse past and cancelled events that are no longer accepting RSVPs.
      </p>
    </div>
    <a
      href="/home"
      class="px-3.5 py-2 rounded-lg bg-white text-blue-700 border border-slate-200 no-underline hover:bg-blue-50 text-sm font-medium"
    >
      Back to Home
    </a>
  </div>
</section>

<% if (pageError) { %>
  <%- include("../partials/error", { message: pageError }) %>
<% } %>

<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <form
    method="GET"
    action="/events/archive"
    hx-get="/events/archive"
    hx-target="#archive-results"
    hx-swap="outerHTML"
    hx-push-url="true"
    class="flex gap-3 items-end flex-wrap"
  >
    <div class="min-w-[220px]">
      <label for="category" class="block text-sm font-medium text-slate-700 mb-2">
        Filter by category
      </label>
      <select
        id="category"
        name="category"
        class="w-full px-3 py-2 border border-slate-300 rounded-lg bg-white"
      >
        <option value="">All categories</option>
        <% categories.forEach((category) => { %>
          <option
            value="<%= category %>"
            <%= selectedCategory === category ? "selected" : "" %>
          >
            <%= category.charAt(0).toUpperCase() + category.slice(1) %>
          </option>
        <% }) %>
      </select>
    </div>

    <button
      type="submit"
      class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium hover:bg-blue-700"
    >
      Apply Filter
    </button>

    <% if (selectedCategory) { %>
      <a
        href="/events/archive"
        hx-get="/events/archive"
        hx-target="#archive-results"
        hx-swap="outerHTML"
        hx-push-url="true"
        class="px-4 py-2 rounded-lg bg-white text-slate-700 border border-slate-200 no-underline hover:bg-slate-50 text-sm font-medium"
      >
        Clear
      </a>
    <% } %>
  </form>
</section>

<%- include("partials/archive-list", { events }) %>
