<section class="mb-5 p-6 border border-slate-200 rounded-2xl bg-gradient-to-b from-white to-slate-50 shadow-lg">
  <h1 class="text-3xl font-bold text-slate-900 mb-3">Welcome to Project Starter</h1>
  <p class="text-slate-500">
    You are signed in and ready to build. This placeholder page is where your
    project's main content will go.
  </p>
  <% if (session.authenticatedUser) { %>
    <p class="text-slate-500 mt-2 mb-0">
      Signed in as <strong class="text-slate-700"><%= session.authenticatedUser.displayName %></strong>
      (<%= session.authenticatedUser.email %>, role:
      <strong class="text-slate-700"><%= session.authenticatedUser.role %></strong>).
    </p>
  <% } %>
</section>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>

<section class="mb-5 max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-semibold">Published Events</h2>
    <a
      href="/events/new"
      class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium no-underline hover:bg-blue-700 text-sm"
    >
      + Create Event
    </a>
  </div>
  <% if (publishedEvents && publishedEvents.length > 0) { %>
    <div class="grid gap-4">
      <% publishedEvents.forEach((event) => { %>
        <article class="rounded-xl border border-slate-200 bg-slate-50 p-4">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h3 class="text-lg font-semibold text-slate-900 mb-1"><%= event.title %></h3>
              <p class="text-slate-500 text-sm mb-2"><%= event.location %> · <%= event.category %></p>
              <p class="text-slate-600 text-sm mb-0"><%= event.description %></p>
            </div>
            <a
              href="/events/<%= event.id %>"
              class="px-3.5 py-2 rounded-lg bg-white text-blue-700 border border-slate-200 no-underline hover:bg-blue-50 text-sm font-medium whitespace-nowrap"
            >
              View Event
            </a>
          </div>
        </article>
      <% }) %>
    </div>
  <% } else { %>
    <p class="text-slate-500 text-sm">No published events yet. Create one to get started.</p>
  <% } %>
</section>

<section class="max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="mb-4">
    <h2 class="text-xl font-semibold mb-2">Getting Started</h2>
    <p class="text-slate-500">
      This starter application provides authentication and role-based authorization
      out of the box. Here are some ideas for where to begin:
    </p>
  </div>

  <ul class="list-disc pl-5 space-y-2 text-slate-700">
    <li>Replace this page with your project's main dashboard or landing page.</li>
    <li>Add new routes in <code class="bg-slate-100 px-1 rounded text-sm">src/app.ts</code> and protect them with
      <code class="bg-slate-100 px-1 rounded text-sm">requireAuthenticated</code> or <code class="bg-slate-100 px-1 rounded text-sm">requireRole</code>.</li>
    <li>Create new EJS views in <code class="bg-slate-100 px-1 rounded text-sm">src/views/</code>.</li>
    <li>Add your own models, services, and controllers under <code class="bg-slate-100 px-1 rounded text-sm">src/</code>.</li>
    <li>Use the Prisma schema in <code class="bg-slate-100 px-1 rounded text-sm">prisma/schema.prisma</code> to define your database tables.</li>
  </ul>
</section>

<section class="max-w-3xl mt-5 p-6 border border-slate-200 rounded-2xl bg-white shadow-lg" x-data="{ open: false }">
  <button
    @click="open = !open"
    class="w-full flex items-center justify-between text-left bg-transparent border-0 p-0 cursor-pointer"
  >
    <h2 class="text-xl font-semibold">Alpine.js Demo</h2>
    <span class="text-slate-400 text-sm" x-text="open ? 'Hide' : 'Show'">Show</span>
  </button>

  <div x-show="open" x-transition class="mt-4">
    <p class="text-slate-500 mb-3">
      Alpine.js is included via CDN and ready to use. This collapsible section is
      a quick demonstration. Use <code class="bg-slate-100 px-1 rounded text-sm">x-data</code>,
      <code class="bg-slate-100 px-1 rounded text-sm">x-show</code>,
      <code class="bg-slate-100 px-1 rounded text-sm">@click</code>, and other
      Alpine directives directly in your EJS templates.
    </p>
    <div x-data="{ count: 0 }" class="flex items-center gap-3">
      <button
        @click="count++"
        class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium cursor-pointer hover:bg-blue-700 text-sm"
      >
        Clicked: <span x-text="count">0</span>
      </button>
      <span class="text-sm text-slate-500">A simple Alpine.js counter</span>
    </div>
  </div>
</section>
