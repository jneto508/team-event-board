<a 
  href="/users/<%= session.authenticatedUser.userId %>/saved-events"
  class="text-blue-600 hover:underline text-sm"
>
  Saved Events
</a>

<div id="search-error"></div>

<% if (pageError) { %>
  <%- include("partials/error", { message: pageError }) %>
<% } %>
<input 
  type="text"
  name="q"
  placeholder="Search events..."
  class="px-3 py-2 border border-slate-300 rounded-lg w-full mb-4"

  hx-get="/events/search"
  hx-trigger="keyup changed delay:500ms"
  hx-target="#event-list"
  hx-swap="innerHTML"
  hx-indicator="#loading"
/>
<div id="loading" style="display:none;" class="text-sm text-slate-500 mb-2">
  Searching...
</div>
<section class="mb-5 max-w-3xl p-6 border border-slate-200 rounded-2xl bg-white shadow-lg">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-xl font-semibold">Published Events</h2>
    <% if (session.authenticatedUser && session.authenticatedUser.role !== "user") { %>
      <a
        href="/events/new"
        class="px-4 py-2 rounded-lg bg-blue-600 text-white font-medium no-underline hover:bg-blue-700 text-sm"
      >
        + Create Event
      </a>
    <% } %>
  </div>
  <div id="event-list">
    <% const eventsToShow = typeof events !== "undefined" ? events : publishedEvents; %>
    <%- include("partials/eventList", { events: eventsToShow }) %>
  </div>
</section>
